    "75": [
      "1949",
      "年，謝國城理事長任職台灣省合作金庫協理時，正值",
      "台灣六家銀行",
      "(",
      "合庫、華銀、一銀、彰銀、台銀、土銀",
      ")",
      "自",
      "辦的行庫棒球賽開打，他擔任開幕典禮時的打擊員貴賓。"
    ],
    "78": [
      "1954",
      "年，謝國城理事長",
      "(",
      "前排中",
      ")",
      "服務於台灣省合作金庫",
      "時，對合庫棒球或桌球運動推廣極為賣力，造就合庫桌、",
      "棒球隊在國內外享有盛譽。"
    ],
    "81": [
      "1959",
      "年，原位於南京東路與敦化北路的台北市市立棒球",
      "場，在謝國城理事長四處籌款及黃啟瑞市長撥公款補助，",
      "經十年施工落成啟用。",
      "(",
      "現址改建台北小巨蛋",
      ")"
    ],
    "84": [
      "1969",
      "年，謝國城總領隊率領首次獲得世界少棒冠軍的金龍",
      "少棒隊，在台北松山機場向到場歡迎的各界首長和代表揮",
      "手致謝。"
    ],
    "87": [
      "1969",
      "年，謝國城理事長在體育界和各方人士極力勸進下，",
      "毅然投入增額立法委員的選舉。交情匪淺的旅日球星王貞",
      "治更是撥空前來助選，果然眾望所歸光榮當選。"
    ],
    "90": [
      "1969",
      "年謝國城先生當選立法委員，為體壇提出許多見解精",
      "闢的質詢稿，他在立委、棒協理事長和民間企業總座的三",
      "重身分下極力扮好每個角色，以實踐宣誓就職時的承諾。"
    ],
    "93": [
      "1970",
      "年，因謝國城理事長曾任日本媒體記者，故對「同",
      "業」特別關照和協助，時有記者深夜來電求證相關事實。",
      "(",
      "右為台視記者傅達仁",
      ")"
    ],
    "96": [
      "1970",
      "年七虎少棒隊雖在世界少棒賽衛冕失敗，返國後嚴副",
      "總統",
      "(",
      "後右四",
      ")",
      "仍接見全體隊員慰勉合影留念。",
      "(",
      "後左四",
      ")",
      "謝",
      "國城總領隊"
    ],
    "99": [
      "1970",
      "世界少棒聯盟麥高文主席",
      "(",
      "左",
      ")",
      "拜訪嚴家淦副總統，嚴",
      "副總統感謝大會給予中華少棒隊的協助與關照，並肯定世",
      "界少棒大賽對各國棒球運動風氣和技術紮根的正面功能。"
    ],
    "102": [
      "1971",
      "年，「亞洲羚羊」紀政小姐訪美為正在威廉波特的選",
      "手加油，與世界少棒聯盟麥高文主席",
      "(",
      "右一",
      ")",
      "謝國城理事長",
      "(",
      "左二",
      ")",
      "林鳳麟副理事長",
      "(",
      "左一",
      ")",
      "留下的合影鏡頭。"
    ],
    "105": [
      "1971",
      "年，巨人少棒隊勇奪世界少棒冠軍，由謝國城總領隊",
      "率隊接受嚴家淦副總統頒贈紀念品，由隊員塗忠男代表接",
      "受。"
    ],
    "108": [
      "1972",
      "年，美和青少棒隊首度代表我國角逐世界青少棒大",
      "賽，結果不負國人期望勇奪冠軍旗，僑胞與留美生興高采",
      "烈與小國手合影留念。"
    ],
    "111": [
      "1972",
      "年，謝國城理事長帶隊出國比賽，常有僑胞或國際友",
      "人設宴款待，謝理事長常以中華隊紀念旗回贈各界的隆情",
      "盛意。"
    ],
    "114": [
      "1972",
      "年，雙十國慶的花車遊行中，揚威國際棒壇的中華隊",
      "國手們，屢屢是大會受矚目的焦點，更是民眾搶拍或請求",
      "合照的熱門對象。"
    ],
    "117": [
      "1976",
      "年，嚴家淦副總統",
      "(",
      "右",
      ")",
      "對謝國城理事長長子謝南強先",
      "生",
      "(",
      "左",
      ")",
      "留美期間，放下學業和工作出錢出力，號召留學生",
      "齊為國手解決在美訓練比賽的交通和困難，表示感謝。"
    ],
    "120": [
      "1976",
      "年，臺灣「少棒之父」謝國城理事長參訪美國道奇職",
      "棒隊主場，大會特以字幕公開歡迎來自中華民國的棒球協",
      "會理事長。"
    ],
    "123": [
      "1977",
      "年，世界足球王比利來臺訪問，經中華足協鄭為元理",
      "事長引荐下，謝國城理事長與比利握手致意，兩位國際體",
      "壇名人相遇，留下珍貴的鏡頭。"
    ],
    "126": [
      "1977",
      "年，華興青少棒隊參加世界青少棒賽遠東區代表權選",
      "拔賽，在台北市立棒球場揭幕，由大會主席謝國城理事長",
      "主持，黃清輝隊長代表各國選手宣誓。"
    ],
    "129": [
      "1977",
      "年，謝國城先生在松山機場停機坪，向行政院長蔣經",
      "國先生展示世界青棒賽冠軍旗。",
      "(",
      "右一",
      ")",
      "張永昌",
      "(",
      "右二",
      ")",
      "徐生",
      "明"
    ],
    "132": [
      "謝國城先生生肖雖不屬馬，卻從在日本留學時即開始收藏",
      "各類材質的馬，尤其喜歡迷你版的馬，收藏共約八百隻。",
      "他原想收集一千隻馬，現在由謝南強先生繼續完成。"
    ]
  },
